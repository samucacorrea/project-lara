GEMINI_API_KEY=your_gemini_api_key

# Frontend
VITE_BACKEND_URL=http://localhost:8080
VITE_APP_URL=http://localhost:3000
VITE_DEBUG_MODE=false

# Backend
APP_URL=http://localhost:8080
APP_KEY=change_this_to_a_long_random_secret
DEBUG_MODE=false
PHP_DISPLAY_ERRORS=0

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=project_lara
DB_USER=project_lara_user
DB_PASSWORD=change_this_password

# Internal warehouse (Postgres)
WAREHOUSE_DRIVER=pgsql
WAREHOUSE_HOST=127.0.0.1
WAREHOUSE_PORT=5432
WAREHOUSE_DB=project_lara_warehouse
WAREHOUSE_USER=project_lara_warehouse_user
WAREHOUSE_PASSWORD=change_this_warehouse_password
WAREHOUSE_SSLMODE=prefer
WAREHOUSE_CONNECT_TIMEOUT=5
WAREHOUSE_QUERY_TIMEOUT=30
WAREHOUSE_RAW_SCHEMA=raw
WAREHOUSE_DERIVED_SCHEMA=derived

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=1.5

# Cache TTLs
DATA_QUERY_CACHE_TTL=300
DATA_QUERY_CACHE_TTL_HISTORICAL=1800
DATA_SOURCES_CACHE_TTL=600
DATA_SOURCE_SCHEMA_CACHE_TTL=900
CALCULATED_METRICS_CACHE_TTL=600
